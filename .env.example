# Production: require this for /api/cron/ingest (Authorization: Bearer <CRON_SECRET> or x-cron-secret)
CRON_SECRET=

# Optional JSON URLs merged on each ingest (array or { "problems": [...] })
UPSTREAM_DSA_URL=
UPSTREAM_SD_URL=

# Override SQLite file path (default: <project>/data/app.db)
# DATABASE_PATH=
